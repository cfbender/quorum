{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/cfbender/quorum/main/schema.json",
  "title": "Quorum configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["members", "triggerMode", "specDir"],
  "properties": {
    "members": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "providerID", "modelID", "label"],
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "providerID": { "type": "string", "minLength": 1 },
          "modelID": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 }
        }
      }
    },
    "triggerMode": { "enum": ["auto", "manual", "off"] },
    "specDir": { "type": "string", "minLength": 1 }
  }
}
